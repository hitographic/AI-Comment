# =============================================
# KONFIGURASI AUTO COMMENT APP
# =============================================

# OpenAI API Key (untuk generate komentar AI)
# Dapatkan di: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Instagram Credentials
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# TikTok Credentials (menggunakan session cookie)
TIKTOK_SESSION_ID=your_tiktok_sessionid_cookie

# App Configuration
SECRET_KEY=your-secret-key-change-this
COMMENT_INTERVAL_MIN=30
COMMENT_INTERVAL_MAX=120
MAX_COMMENTS_PER_DAY=50

# Mode: 'ai' untuk OpenAI, 'template' untuk template komentar
COMMENT_MODE=template
